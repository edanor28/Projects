generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ====================================================================
// ENUMS (Tipado estricto a nivel de Base de Datos)
// ====================================================================

enum Role {
  MANAGER
  WORKER
  CLIENT
}

enum OrderStatus {
  PENDING      // Cliente hizo el pedido, esperando pago/confirmación
  PROCESSING   // En taller metalúrgico
  COMPLETED    // Listo para entrega/recogida
  CANCELLED    // Cancelado (Soft delete logico)
}

// ====================================================================
// MODELOS CORE (Seguridad y Usuarios)
// ====================================================================

model User {
  // SEGURIDAD: Usamos UUID en lugar de Int Autoincremental para mitigar 
  // ataques IDOR (Insecure Direct Object Reference). Nadie podrá adivinar IDs.
  id            String    @id @default(uuid())
  
  email         String    @unique
  passwordHash  String    // NUNCA guardar contraseñas en texto plano. Usaremos Argon2id en el backend.
  
  firstName     String
  lastName      String
  role          Role      @default(CLIENT)
  
  // SEGURIDAD: Soft Deletes. Nunca borramos registros con DELETE, cambiamos su estado.
  // Esto mantiene la integridad referencial y las auditorías intactas.
  isActive      Boolean   @default(true)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relaciones
  orders        Order[]   @relation("ClientOrders")
  messages      Message[]
}

// ====================================================================
// MODELOS DE NEGOCIO (Metalurgia)
// ====================================================================

model Product {
  id            String    @id @default(uuid())
  name          String
  description   String?
  
  // Guardamos los precios en centavos (Int) para evitar errores de precisión de coma flotante.
  priceCents    Int       
  
  stockQuantity Int       @default(0)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relaciones
  orderItems    OrderItem[]
}

model Order {
  id            String      @id @default(uuid())
  status        OrderStatus @default(PENDING)
  totalCents    Int         // Total pre-calculado para validación rápida
  
  clientId      String
  client        User        @relation("ClientOrders", fields: [clientId], references: [id])
  
  items         OrderItem[]
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model OrderItem {
  id            String    @id @default(uuid())
  quantity      Int
  
  // Snapshot del precio en el momento de la compra (inmutable)
  unitPriceCents Int      

  orderId       String
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId     String
  product       Product   @relation(fields: [productId], references: [id])
}

// ====================================================================
// MODELOS DE COMUNICACIÓN (Chat WSS)
// ====================================================================

model Message {
  id            String    @id @default(uuid())
  content       String    // Será saneado contra XSS en el Backend antes de insertarse
  
  senderId      String
  sender        User      @relation(fields: [senderId], references: [id])
  
  createdAt     DateTime  @default(now())
}