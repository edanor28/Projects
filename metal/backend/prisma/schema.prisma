datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ====================================================================
// ENUMS (Tipado estricto a nivel de Base de Datos)
// ====================================================================

enum Role {
  MANAGER
  WORKER
  CLIENT
}

enum OrderStatus {
  PENDING    // Esperando aprobación del Gerente
  APPROVED   // Aprobado, listo para ser despachado por el Trabajador
  REJECTED   // Rechazado por falta de stock o problemas de pago
  FULFILLED  // Entregado al cliente
}

// ====================================================================
// MODELOS CORE (Seguridad y Usuarios)
// ====================================================================

model User {
  // SEGURIDAD: Usamos UUID en lugar de Int Autoincremental para mitigar 
  // ataques IDOR (Insecure Direct Object Reference). Nadie podrá adivinar IDs.
  id String @id @default(uuid())

  email        String @unique
  passwordHash String // NUNCA guardar contraseñas en texto plano. Usaremos Argon2id en el backend.

  firstName String
  lastName  String
  role      Role   @default(CLIENT)

  // SEGURIDAD: Soft Deletes. Nunca borramos registros con DELETE, cambiamos su estado.
  // Esto mantiene la integridad referencial y las auditorías intactas.
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  orders    Order[]
  messages  Message[]
  auditLogs AuditLog[]
}

// ====================================================================
// MODELOS DE NEGOCIO (Metalurgia)
// ====================================================================

model Product {
  id          String  @id @default(uuid())
  name        String
  description String?

  // Guardamos los precios en centavos (Int) para evitar errores de precisión de coma flotante.
  priceCents Int

  stockQuantity Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  orderItems OrderItem[]
}

model Order {
  id         String      @id @default(uuid())
  userId     String
  status     OrderStatus @default(PENDING)
  totalCents Int         // Total pre-calculado en el backend, NUNCA confiamos en el cliente

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items  OrderItem[]

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id         String @id @default(uuid())
  orderId    String
  productId  String
  quantity   Int
  priceCents Int    // Snapshot del precio en el momento de la compra

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

// ====================================================================
// MODELOS DE COMUNICACIÓN (Chat WSS)
// ====================================================================

model Message {
  id      String @id @default(uuid())
  content String // Será saneado contra XSS en el Backend antes de insertarse

  senderId String
  sender   User   @relation(fields: [senderId], references: [id])

  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String
  userId    String
  details   Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([entity, entityId])
}
